rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAdmin() {
      return request.auth != null;
    }
    
    function isValidReview() {
      let data = request.resource.data;
      return data.status == 'pending' && 
             data.name is string && data.name.size() > 0 &&
             data.comment is string && data.comment.size() > 0;
    }

    // Reviews Collection
    match /reviews/{reviewId} {
      // Anyone can read approved reviews or view pending ones (admin uses this)
      allow read: if true;
      
      // Anyone can submit a review, but it must start as 'pending'
      allow create: if isValidReview();
      
      // Only admin can approve or delete
      allow update, delete: if isAdmin();
      
      // Images subcollection
      match /images/{imageId} {
        allow read: if true;
        allow write: if isAdmin() || (request.method == 'create' && request.auth == null);
      }
    }

    // Heritage Sites Collection
    match /sites/{siteId} {
      // Publicly readable
      allow read: if true;
      
      // Admin only write access
      allow write: if isAdmin();
    }
    
    // Default deny for anything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
